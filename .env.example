# ── Docker ────────────────────────────────────────────────────────────────────

# Image name and tag used when building / pushing.
IMAGE_NAME=gravity
IMAGE_TAG=latest

# Host port the production nginx container binds to.
APP_PORT=8080

# Host port the Vite dev server binds to.
DEV_PORT=5173

# Node.js image tag used by the dev service.
NODE_VERSION=20-alpine

# Container restart policy (no | always | on-failure | unless-stopped).
RESTART_POLICY=unless-stopped

# Healthcheck timing.
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=10s
